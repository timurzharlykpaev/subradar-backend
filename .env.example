# =========================================================================
#  SubRadar Backend — environment variables
#
#  Copy to `.env` for local dev. Production/dev servers receive these via
#  GitHub Actions (see .github/workflows/deploy.yml). Never commit real
#  secrets to git — rotate immediately if you do.
# =========================================================================

# === Runtime ===
NODE_ENV=development                # development | production | test
PORT=3200                           # HTTP listen port (prod uses 8080)

# === Database (Postgres) ===
# Full URL is preferred; when set, DB_HOST/DB_PORT/... are ignored.
DATABASE_URL=postgresql://user:password@localhost:5432/subradar
DB_HOST=localhost                   # fallback when DATABASE_URL is not set
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=subradar
DB_SSL=false                        # true in production (DigitalOcean managed DB)

# === Cache & queues (Redis) ===
# Used by BullMQ job queues, throttler storage, and ad-hoc caches.
REDIS_URL=redis://localhost:6379

# === JWT / session ===
# All three must be >= 32 random chars. Use: `openssl rand -hex 48`
JWT_ACCESS_SECRET=CHANGE_ME_RANDOM_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_RANDOM_64_CHARS
MAGIC_LINK_SECRET=CHANGE_ME_RANDOM_64_CHARS
JWT_EXPIRES_IN=7d                   # access-token lifetime
JWT_REFRESH_EXPIRES_IN=30d          # refresh-token lifetime

# === OAuth providers ===
# Web OAuth (Google Sign-In redirect flow).
GOOGLE_CLIENT_ID=xxx                # web app OAuth client id
GOOGLE_CLIENT_SECRET=xxx            # web app OAuth client secret
GOOGLE_CALLBACK_URL=http://localhost:3200/api/v1/auth/google/callback

# Mobile OAuth (ID-token flow — verified server-side).
GOOGLE_CLIENT_ID_IOS=               # iOS app Google OAuth client ID
GOOGLE_CLIENT_ID_ANDROID=           # Android app Google OAuth client ID

# Apple Sign-In (iOS/web).
APPLE_CLIENT_ID=com.goalin.subradar # bundle ID used as `aud` in Apple id_token

# App Store review backdoor. When `true`, the email review@subradar.ai will
# receive a fixed OTP "000000" so Apple reviewers can log in. MUST be unset
# (or !== 'true') in production except while a build is actively under review.
ENABLE_REVIEW_ACCOUNT=false

# === Email (Resend) ===
# Used for magic links, OTPs, receipts, billing notifications.
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@subradar.ai

# === Frontend URLs / CORS ===
APP_URL=https://app.subradar.ai     # primary web app URL (used in emails)
FRONTEND_URL=https://app.subradar.ai # alias of APP_URL — prefer APP_URL
CORS_ORIGINS=http://localhost:3000,http://localhost:5173   # comma-separated

# === AI (OpenAI) ===
# Powers voice-to-subscription, screenshot parsing, smart lookup.
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o                 # model id used for all AI endpoints

# === Object storage (DigitalOcean Spaces, S3-compatible) ===
# Stores receipts, user avatars, exported report PDFs.
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=subradar
DO_SPACES_REGION=fra1
DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com

# === Payments — Lemon Squeezy (web) ===
LEMON_SQUEEZY_API_KEY=xxx
LEMON_SQUEEZY_WEBHOOK_SECRET=xxx
# Optional secondary secret accepted during key rotation. Set to the NEW
# secret BEFORE flipping LEMON_SQUEEZY_WEBHOOK_SECRET in Lemon Squeezy. Once
# all incoming signatures match the primary, unset this variable.
LEMON_SQUEEZY_WEBHOOK_SECRET_V2=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_PRO_MONTHLY_VARIANT_ID=
LEMON_SQUEEZY_PRO_YEARLY_VARIANT_ID=
LEMON_SQUEEZY_TEAM_MONTHLY_VARIANT_ID=
LEMON_SQUEEZY_TEAM_YEARLY_VARIANT_ID=

# === Payments — RevenueCat (mobile IAP) ===
REVENUECAT_WEBHOOK_SECRET=CHANGE_ME     # shared secret for webhook signature
# Public/legacy SDK key — kept for backwards compatibility
REVENUECAT_API_KEY=CHANGE_ME
# REST API v1 **secret** key used for server-side entitlement verification
# (see https://www.revenuecat.com/docs/service/api-reference). REQUIRED for
# /billing/sync-revenuecat to work — without it the endpoint returns 503.
REVENUECAT_API_KEY_SECRET=CHANGE_ME

# === Push notifications — Firebase / FCM ===
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=               # full PEM incl. literal \n newlines

# === Email import (webhook ingest) ===
# Shared token for the email-forwarding webhook so third parties can't inject
# fake receipts. Rotate if leaked.
EMAIL_IMPORT_TOKEN=CHANGE_ME

# === Ops / observability (optional) ===
# Telegram alerts from TelegramAlertService (crashes, deploy notifications).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === TLS (production only) ===
# DigitalOcean managed DB uses a self-signed CA — disable strict verification.
# See comment in src/app.module.ts explaining the risk tradeoff.
# NODE_TLS_REJECT_UNAUTHORIZED=0
