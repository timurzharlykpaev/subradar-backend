NODE_ENV=development
PORT=3200

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/subradar
DB_SSL=false

# JWT
JWT_ACCESS_SECRET=CHANGE_ME_RANDOM_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_RANDOM_64_CHARS
MAGIC_LINK_SECRET=CHANGE_ME_RANDOM_64_CHARS

# Redis
REDIS_URL=redis://localhost:6379

# Google OAuth
GOOGLE_CLIENT_ID=xxx
GOOGLE_CLIENT_SECRET=xxx

# Resend (email)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@subradar.ai

# App
APP_URL=https://app.subradar.ai

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Email Import
EMAIL_IMPORT_TOKEN=CHANGE_ME

# RevenueCat
REVENUECAT_WEBHOOK_SECRET=CHANGE_ME

# Lemon Squeezy
LEMON_SQUEEZY_API_KEY=xxx
LEMON_SQUEEZY_WEBHOOK_SECRET=xxx

# Apple Sign-In
APPLE_CLIENT_ID=com.goalin.subradar
